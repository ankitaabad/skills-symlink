{
  "name": "skills-symlink",
  "version": "0.0.4",
  "description": "Manage a central skills registry (e.g. ~/skills) and symlink a subset into the current project.",
  "type": "module",
  "bin": {
    "skl": "./dist/cli.js",
    "skills-symlink": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm test",
    "publish": "npm publish"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "skills",
    "symlink",
    "ai",
    "agents",
    "opencode",
    "claude",
    "cursor"
  ],
  "license": "MIT"
}
